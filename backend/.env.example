# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mrbar:mrbar@localhost:5432/mrbar?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ─
JWT_ACCESS_SECRET="change-me-to-64-random-bytes-hex"
JWT_REFRESH_SECRET="change-me-to-another-64-random-bytes-hex"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS (comma-separated list, no wildcards in production) ─────────────────
ALLOWED_ORIGINS="http://localhost:3001"

# ─── Business Panel URL (for Stripe redirect) ────────────────────────────────
BUSINESS_PANEL_URL="http://localhost:3001"

# ─── Firebase Admin SDK (push notifications) ─────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ─── Twilio (SMS OTP) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── AWS S3 (file uploads) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION="eu-west-1"

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_ENTERPRISE=""
